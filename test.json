         "description": "Slaps the foe with a strand of silk."
      },
      {
         "id": 1365,
         "skill": "Silk Thread Gather",
         "translation": "",
         "description": "Shoots out silk in the shape of a hand to grab objects."
      },
      {
         "id": 1366,
         "skill": "Worm Tail",
         "translation": "",
         "description": "Spins around and scratches the foe with its spinnerets."
      },
      {
         "id": 1367,
         "skill": "Worm Wheel",
         "translation": "",
         "description": "Spins into a ball and rams enemy."
      },
      {
         "id": 1368,
         "skill": "Worm Scratch",
         "translation": "",
         "description": "Jumps in the air and spins into a ball to attack."
      },
      {
         "id": 1369,
         "skill": "Worm Hang",
         "translation": "",
         "description": "Sticks to a surface, allowing it to scale it. Attaches itself to an enemy to headbutt it repeatedly."
      },
      {
         "id": 437,
         "skill": "Petit Tackle",
         "translation": "",
         "description": ""
      },
      {
         "id": 1370,
         "skill": "Thread Punch",
         "translation": "",
         "description": ""Punches" with a blob of silk extended from its mouth."
      },
      {
         "id": 1371,
         "skill": "Spin Sting",
         "translation": "",
         "description": "Drills the enemy with its spinnerets."
      },
      {
         "id": 1372,
         "skill": "Thread Clump Drop",
         "translation": "",
         "description": "Encases a midair opponent in webbing, making them fall to the ground."
      },
      {
         "id": 1373,
         "skill": "Spiked Smash",
         "translation": "",
         "description": "Sprays webbing along the ground and forms it into spikes that stab upward at the enemy."
      },
      {
         "id": 1374,
         "skill": "Worm Drill Crash",
         "translation": "",
         "description": "Dives down at the enemy, drilling them with a spike of webbing protruded from its mouth."
      },
      {
         "id": 1375,
         "skill": "Dynamic Thread Uppercut",
